rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Anyone with a code hash can read a single invitee record.
    // Writes should only happen from trusted/admin contexts.
    match /invitees/{inviteeId} {
      allow read: if true;
      allow write: if false;
    }

    // RSVP submissions are currently unauthenticated from the public RSVP page.
    // Consider tightening these rules by App Check / auth / server-side writes later.
    match /rsvps/{rsvpId} {
      allow create: if true;
      allow read, update, delete: if false;
    }
  }
}
